# ---------------------------------------------------------------------------
# Copilot CRM backend - environment configuration
# Copy to .env and fill in. Everything works with NO keys (mock LLM) for demos.
# ---------------------------------------------------------------------------

# HTTP server
PORT=3000

# --- Scoring engine -------------------------------------------------------
# auto  : try the Python models (Models/score_batch.py), fall back to JS
# python: Python models only
# js    : pure-JS engine using exported trained params (Models/artifacts/model_params.json)
SCORING_ENGINE=auto
PYTHON_BIN=python
# Override paths only if the Models folder is not the repo-root sibling of backend/
# MODELS_DIR=../Models
# MODEL_PARAMS_PATH=../Models/artifacts/model_params.json
# SCORE_BATCH_SCRIPT=../Models/score_batch.py
SCORING_TIMEOUT_MS=30000

# --- LLM provider ---------------------------------------------------------
# azure | openai | mock   (mock needs no credentials)
LLM_PROVIDER=azure

# Azure OpenAI (default)
# Endpoint may be the resource base (https://<res>.openai.azure.com) OR the
# Foundry style with a /openai/v1 suffix — both are handled.
AZURE_OPENAI_ENDPOINT=
AZURE_OPENAI_API_KEY=
# DEPLOYMENT is the name you gave the model deployment in Azure AI Foundry
# (Deployments tab), e.g. gpt-4o-mini or gpt-5-mini — NOT the model family.
AZURE_OPENAI_DEPLOYMENT=
AZURE_OPENAI_API_VERSION=2024-08-01-preview

# OpenAI (set LLM_PROVIDER=openai)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
# OPENAI_BASE_URL=https://api.openai.com/v1

# LLM behavior
LLM_TIMEOUT_MS=30000
LLM_MAX_TOKENS=1400
# Extra token budget added for reasoning models (GPT-5 / o-series) so their
# hidden reasoning tokens don't starve the JSON output. Ignored by other models.
LLM_REASONING_HEADROOM=4000
LLM_TEMPERATURE=0.4

# --- Product / domain -----------------------------------------------------
PRODUCT_NAME=Microsoft 365 Copilot

# --- Email sending (AI outreach) ------------------------------------------
# HARD SAFETY GATE. Real email is NEVER sent unless MAIL_SEND_ENABLED=true AND a
# provider (smtp|graph) is fully configured. Default = mock outbox (records
# "sends" but delivers nothing).
MAIL_SEND_ENABLED=false
MAIL_PROVIDER=mock          # mock | smtp | graph
MAIL_FROM=value-iq@example.com
# Default AI autonomy for new leads: manual (draft only) | approval (queue for
# human OK) | auto (AI sends when the gate is on).
DEFAULT_AUTONOMY=manual

# SMTP (set MAIL_PROVIDER=smtp). E.g. SendGrid, an O365 app password, etc.
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_SECURE=false

# Microsoft Graph application send (set MAIL_PROVIDER=graph). Needs an Entra app
# with Mail.Send application permission + admin consent (often blocked on student
# tenants — SMTP is the easier real path there).
GRAPH_TENANT_ID=
GRAPH_CLIENT_ID=
GRAPH_CLIENT_SECRET=
GRAPH_SENDER=               # the mailbox UPN to send as

# --- Lead score weights (must sum to ~1; optional override) ---------------
# LEAD_SCORE_WEIGHTS={"expansion":0.40,"value":0.25,"waste":0.20,"size":0.15}
# Deal-size reference: monthly license spend (USD) that maps to a full size score.
LEAD_SCORE_SIZE_REF_USD=100000
